# TVEdit.cfg.example
#
# Copy this file to TVEdit.cfg next to the TVEdit executable.
# Rename it to TVEdit.cfg (remove the .example suffix).
# Only the settings you specify are applied; missing settings preserve defaults.
#
# Supported keys:
#   [driver]  name      - Driver to use: sdl | console
#   [sdl]     fontName  - Font family name for the SDL driver

[driver]
name=sdl

[sdl]
fontName=Cascadia Mono
